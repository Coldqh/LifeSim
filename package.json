  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20.19.0 <25",
    "npm": ">=10 <12"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
